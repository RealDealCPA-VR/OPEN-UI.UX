{
  "name": "@opencodex/runner-opencode",
  "version": "0.0.0",
  "private": true,
  "description": "OpenCode agent runner for OpenCodex",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@opencodex/core": "workspace:*",
    "@opencodex/plugin-sdk": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "optionalDependencies": {
    "opencode": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "opencode": {
      "optional": true
    }
  }
}
