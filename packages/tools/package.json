{
  "name": "@opencodex/tools",
  "version": "0.0.0",
  "description": "Built-in tool implementations: read_file, write_file, read_document, write_document, edit_file, glob, grep, list_dir, run_shell, web_fetch",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@opencodex/core": "workspace:*",
    "docx": "^9.7.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "picomatch": "^4.0.4",
    "unpdf": "^1.6.2",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/picomatch": "^3.0.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
