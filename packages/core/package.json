{
  "name": "@opencodex/core",
  "version": "0.0.0",
  "description": "OpenCodex core contracts: LLMProvider, Tool, ChatEvent, ModelCapabilities",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./process/tree-kill": {
      "types": "./dist/process/tree-kill.d.ts",
      "import": "./dist/process/tree-kill.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers/index.d.ts",
      "import": "./dist/test-helpers/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
