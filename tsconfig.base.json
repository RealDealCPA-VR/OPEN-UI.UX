{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "paths": {
      "@opencodex/core": ["./packages/core/src/index.ts"],
      "@opencodex/core/*": ["./packages/core/src/*"],
      "@opencodex/provider-openai": ["./packages/provider-openai/src/index.ts"],
      "@opencodex/provider-openai/*": ["./packages/provider-openai/src/*"],
      "@opencodex/provider-anthropic": ["./packages/provider-anthropic/src/index.ts"],
      "@opencodex/provider-anthropic/*": ["./packages/provider-anthropic/src/*"],
      "@opencodex/provider-google": ["./packages/provider-google/src/index.ts"],
      "@opencodex/provider-google/*": ["./packages/provider-google/src/*"],
      "@opencodex/provider-xai": ["./packages/provider-xai/src/index.ts"],
      "@opencodex/provider-xai/*": ["./packages/provider-xai/src/*"],
      "@opencodex/provider-mistral": ["./packages/provider-mistral/src/index.ts"],
      "@opencodex/provider-mistral/*": ["./packages/provider-mistral/src/*"],
      "@opencodex/provider-ollama": ["./packages/provider-ollama/src/index.ts"],
      "@opencodex/provider-ollama/*": ["./packages/provider-ollama/src/*"],
      "@opencodex/provider-openrouter": ["./packages/provider-openrouter/src/index.ts"],
      "@opencodex/provider-openrouter/*": ["./packages/provider-openrouter/src/*"],
      "@opencodex/tools": ["./packages/tools/src/index.ts"],
      "@opencodex/tools/*": ["./packages/tools/src/*"],
      "@opencodex/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@opencodex/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@opencodex/mcp-client": ["./packages/mcp-client/src/index.ts"],
      "@opencodex/mcp-client/*": ["./packages/mcp-client/src/*"],
      "@opencodex/rag-chunker": ["./packages/rag-chunker/src/index.ts"],
      "@opencodex/rag-chunker/*": ["./packages/rag-chunker/src/*"],
      "@opencodex/code-graph": ["./packages/code-graph/src/index.ts"],
      "@opencodex/code-graph/*": ["./packages/code-graph/src/*"],
      "@opencodex/memory-obsidian": ["./packages/memory-obsidian/src/index.ts"],
      "@opencodex/memory-obsidian/*": ["./packages/memory-obsidian/src/*"],
      "@opencodex/memory-notion": ["./packages/memory-notion/src/index.ts"],
      "@opencodex/memory-notion/*": ["./packages/memory-notion/src/*"],
      "@opencodex/memory-local-fs": ["./packages/memory-local-fs/src/index.ts"],
      "@opencodex/memory-local-fs/*": ["./packages/memory-local-fs/src/*"],
      "@opencodex/memory-utils": ["./packages/memory-utils/src/index.ts"],
      "@opencodex/memory-utils/*": ["./packages/memory-utils/src/*"],
      "@opencodex/telemetry": ["./packages/telemetry/src/index.ts"],
      "@opencodex/telemetry/*": ["./packages/telemetry/src/*"],
      "@opencodex/crash-reporting": ["./packages/crash-reporting/src/index.ts"],
      "@opencodex/crash-reporting/*": ["./packages/crash-reporting/src/*"],
      "@opencodex/audit-verify": ["./packages/audit-verify/src/index.ts"],
      "@opencodex/audit-verify/*": ["./packages/audit-verify/src/*"],
      "@opencodex/provider-voyage": ["./packages/provider-voyage/src/index.ts"],
      "@opencodex/provider-voyage/*": ["./packages/provider-voyage/src/*"],
      "@opencodex/runner-aider": ["./packages/runner-aider/src/index.ts"],
      "@opencodex/runner-aider/*": ["./packages/runner-aider/src/*"],
      "@opencodex/runner-claude-code": ["./packages/runner-claude-code/src/index.ts"],
      "@opencodex/runner-claude-code/*": ["./packages/runner-claude-code/src/*"],
      "@opencodex/runner-opencode": ["./packages/runner-opencode/src/index.ts"],
      "@opencodex/runner-opencode/*": ["./packages/runner-opencode/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "out"]
}
