{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@main/*": ["src/main/*"],
      "@shared/*": ["src/shared/*"],
      "@opencodex/core": ["../../packages/core/src/index.ts"],
      "@opencodex/core/*": ["../../packages/core/src/*"],
      "@opencodex/providers": ["../../packages/providers/src/index.ts"],
      "@opencodex/providers/*": ["../../packages/providers/src/*"],
      "@opencodex/tools": ["../../packages/tools/src/index.ts"],
      "@opencodex/tools/*": ["../../packages/tools/src/*"],
      "@opencodex/plugin-sdk": ["../../packages/plugin-sdk/src/index.ts"],
      "@opencodex/plugin-sdk/*": ["../../packages/plugin-sdk/src/*"],
      "@opencodex/mcp-client": ["../../packages/mcp-client/src/index.ts"],
      "@opencodex/mcp-client/*": ["../../packages/mcp-client/src/*"]
    }
  },
  "include": ["src/**/*", "electron.vite.config.ts"]
}
