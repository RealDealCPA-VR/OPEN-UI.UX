{
  "name": "@opencodex/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "OpenCodex Electron desktop app",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "predev": "node scripts/ensure-native-abi.mjs electron",
    "dev": "node scripts/build-runner-plugins.mjs && node scripts/dev.cjs",
    "prebuild": "node scripts/ensure-native-abi.mjs electron",
    "build": "node scripts/build-runner-plugins.mjs && node scripts/copy-grammars.mjs && electron-vite build",
    "build:plugins": "node scripts/build-runner-plugins.mjs",
    "copy-grammars": "node scripts/copy-grammars.mjs",
    "preview": "electron-vite preview",
    "package": "node scripts/build-runner-plugins.mjs && node scripts/copy-grammars.mjs && electron-vite build && electron-builder --dir",
    "dist": "node scripts/build-runner-plugins.mjs && node scripts/copy-grammars.mjs && electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts e2e",
    "pretest": "node scripts/ensure-native-abi.mjs node",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "bench": "node scripts/bench.mjs",
    "clean": "rimraf out release .vite",
    "rebuild-native": "node scripts/ensure-native-abi.mjs electron",
    "rebuild-native-node": "node scripts/ensure-native-abi.mjs node",
    "postinstall": "node scripts/ensure-native-abi.mjs electron || echo 'rebuild-native skipped — run pnpm rebuild-native manually'"
  },
  "dependencies": {
    "@opencodex/audit-verify": "workspace:*",
    "@opencodex/code-graph": "workspace:*",
    "@opencodex/core": "workspace:*",
    "@opencodex/crash-reporting": "workspace:*",
    "@opencodex/mcp-client": "workspace:*",
    "@opencodex/memory-local-fs": "workspace:*",
    "@opencodex/memory-notion": "workspace:*",
    "@opencodex/memory-obsidian": "workspace:*",
    "@opencodex/plugin-sdk": "workspace:*",
    "@opencodex/provider-anthropic": "workspace:*",
    "@opencodex/provider-google": "workspace:*",
    "@opencodex/provider-mistral": "workspace:*",
    "@opencodex/provider-ollama": "workspace:*",
    "@opencodex/provider-openai": "workspace:*",
    "@opencodex/provider-openrouter": "workspace:*",
    "@opencodex/provider-voyage": "workspace:*",
    "@opencodex/provider-xai": "workspace:*",
    "@opencodex/rag-chunker": "workspace:*",
    "@opencodex/telemetry": "workspace:*",
    "@opencodex/tools": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.3",
    "cron-parser": "^4.9.0",
    "cytoscape": "^3.30.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "gray-matter": "^4.0.3",
    "keytar": "^7.9.0",
    "mermaid": "^11.15.0",
    "pino": "^9.5.0",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@monaco-editor/react": "^4.6.0",
    "@playwright/test": "^1.42.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cytoscape": "^3.21.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.1.0",
    "esbuild": "^0.21.5",
    "jsdom": "^25.0.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
