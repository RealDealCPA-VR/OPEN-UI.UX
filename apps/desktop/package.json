{
  "name": "@opencodex/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "OpenCodex Electron desktop app",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "clean": "rimraf out release .vite"
  },
  "dependencies": {
    "@opencodex/core": "workspace:*",
    "@opencodex/mcp-client": "workspace:*",
    "@opencodex/plugin-sdk": "workspace:*",
    "@opencodex/providers": "workspace:*",
    "@opencodex/tools": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
