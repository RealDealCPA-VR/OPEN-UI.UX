# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo
# Stray tsc emit artifacts in src/ — emit directs to dist/, but if anyone
# accidentally runs `tsc` from a package without `-p tsconfig.json` (or in a
# mode that emits next to source), these patterns keep the noise out of git
# and ESLint.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Electron
apps/desktop/release/
apps/desktop/.vite/

# Per-project agent state (created by OpenCodex inside user repos)
.opencodex/

# Claude Code per-user local settings — machine paths + command history, never commit
.claude/settings.local.json

# Env / secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test artifacts
coverage/
playwright-report/
test-results/

# Misc
.turbo/
.cache/
